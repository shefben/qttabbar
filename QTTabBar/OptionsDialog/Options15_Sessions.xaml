<?xml version="1.0" encoding="UTF-8"?>
<qt:OptionsDialogTab
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:qt="clr-namespace:QTTabBarLib"
    x:Class="QTTabBarLib.Options15_Sessions"
    x:ClassModifier="internal">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="OptionsDialogResources.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <DockPanel Margin="14,5,10,16">
        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,4" Orientation="Horizontal">
            <Image
                Source="{Binding Source={x:Static qt:Resources_Image.imgTabWindow}, Converter={StaticResource BitmapToImageSourceConverter}}"
                Style="{StaticResource PageHeaderImageStyle}"/>
            <Label
                Content="{qt:Resx Key=Options_Page15_Sessions, Index=0}"
                FontSize="13"
                VerticalAlignment="Bottom"/>
        </StackPanel>

        <TextBlock
            DockPanel.Dock="Top"
            Margin="5,10,5,12"
            Text="{qt:Resx Key=Options_Page15_Sessions, Index=1}"
            TextWrapping="Wrap"/>

        <DockPanel Margin="0,0,0,10">
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                <Button x:Name="btnRefresh"
                    Width="110"
                    Height="23"
                    Margin="4,0,0,0"
                    Click="btnRefresh_Click"
                    Content="{qt:Resx Key=Options_Page15_Sessions, Index=3}"/>
                <Button x:Name="btnOpen"
                    Width="140"
                    Height="23"
                    Margin="4,0,0,0"
                    Click="btnOpen_Click"
                    Content="{qt:Resx Key=Options_Page15_Sessions, Index=2}"/>
            </StackPanel>
        </DockPanel>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Border
                BorderBrush="{StaticResource OptionsPaneBorderBrush}"
                BorderThickness="1"
                CornerRadius="2">
                <ListBox x:Name="lstSessions"
                    Background="White"
                    BorderThickness="0"
                    HorizontalContentAlignment="Stretch"
                    MouseDoubleClick="lstSessions_MouseDoubleClick"
                    SelectionChanged="lstSessions_SelectionChanged">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="4" ToolTip="{Binding Tooltip}">
                                <TextBlock
                                    FontWeight="Bold"
                                    Text="{Binding Title}"/>
                                <TextBlock
                                    Foreground="Gray"
                                    Margin="0,2,0,0"
                                    Text="{Binding Summary}"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>
            <TextBlock x:Name="txtEmpty"
                Grid.Row="0"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Foreground="Gray"
                Text="{qt:Resx Key=Options_Page15_Sessions, Index=4}"/>
        </Grid>
    </DockPanel>
</qt:OptionsDialogTab>